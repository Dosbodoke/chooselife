{
  "name": "chooselife-mobile",
  "main": "expo-router/entry",
  "version": "1.3.16",
  "private": true,
  "scripts": {
    "dev": "expo start -c",
    "dev:web": "expo start -c --web",
    "dev:android": "expo start -c --android",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start -c --web",
    "lint": "eslint .",
    "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\"",
    "format:translations": "eslint --fix --format node_modules/eslint-plugin-i18n-json/formatter.js ./i18n/locales",
    "postinstall": "patch-package",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev:test:ota": "EXPO_PUBLIC_TEST_OTA=true expo start",
    "dev:test:store": "EXPO_PUBLIC_TEST_STORE=true expo start",
    "maestro": "maestro test .maestro/",
    "maestro:ota": "maestro test .maestro/updates/ota-update-prompt.yaml && maestro test .maestro/updates/ota-update-now.yaml && maestro test .maestro/updates/ota-remind-later.yaml",
    "maestro:store": "maestro test .maestro/updates/store-update-required.yaml",
    "maestro:studio": "maestro studio"
  },
