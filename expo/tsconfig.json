{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["jest", "react", "react-native"],
    "paths": {
      "~/*": ["./*"],
      "@packages/database/*": ["../packages/database/*"],
      "@chooselife/ui": ["../packages/ui/src"]
    },
    "jsx": "react-native",
    "esModuleInterop": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "uniwind-types.d.ts"
  ],
}
